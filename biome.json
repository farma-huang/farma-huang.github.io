{
	"files": {
		"includes": [
			"**",
			"!**/*.css",
			"!!**/node_modules",
			"!!**/.astro",
			"!!**/dist",
			"!!**/.agent"
		]
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"jsxQuoteStyle": "double",
			"quoteProperties": "asNeeded",
			"trailingCommas": "all",
			"semicolons": "asNeeded",
			"bracketSameLine": true,
			"bracketSpacing": true
		}
	},
	"overrides": [
		{
			"includes": [
				"**/*.svelte",
				"**/*.astro",
				"**/*.vue",
				"**/*.ts",
				"**/*.tsx"
			],
			"formatter": {
				"enabled": true,
				"indentStyle": "space",
				"indentWidth": 2,
				"lineWidth": 80
			},
			"linter": {
				"rules": {
					"style": {
						"useConst": "off",
						"useImportType": "off",
						"noNonNullAssertion": "off"
					},
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off",
						"useExhaustiveDependencies": "off"
					},
					"suspicious": {
						"noExplicitAny": "off",
						"noArrayIndexKey": "off"
					}
				}
			}
		}
	]
}
