---
import BreathingApp from '@components/breathing/BreathingApp'
import BaseLayout from '../../../layouts/BaseLayout.astro'

const pageTitle = '4-7-8 呼吸法 - Farma'
---

<BaseLayout pageTitle={pageTitle}>
  <div class="py-12 px-4 lg:px-8 bg-[#1f1e1b] min-h-screen text-amber-50">
    <div class="max-w-4xl mx-auto">
      <div class="mb-12 text-center">
        <h1 class="text-4xl lg:text-5xl font-extrabold text-[#d2b48c] mb-6 drop-shadow-sm">
          4-7-8 呼吸法
        </h1>
      </div>

      <div class="w-full rounded-[2.5rem] bg-[#2a2824] shadow-2xl overflow-hidden ring-1 ring-[#d2b48c]/20">
        <BreathingApp client:load />
      </div>
    </div>
  </div>
</BaseLayout>
