---

<BaseLayout pageTitle={pageTitle}>
  <div class="px-3 py-8 lg:p-12">
    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-black mb-2">作品集</h1>
      <p class="text-zinc-600 text-base">
        這裡收錄了我參與開發或獨立完成的專案，涵蓋 Web 應用、工具開發與資料平台。
      </p>
    </div>

    <!-- Cards Grid: 2 columns -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        projects.map((project) => {
          const Tag = project.link ? 'a' : 'div'
          return (
            <Tag
              href={project.link || undefined}
              rel={project.link ? 'noopener noreferrer' : undefined}
              class={`rounded-2xl border border-zinc-200 bg-card-bg shadow-sm p-6 flex flex-col gap-4 transition-shadow${project.link ? ' hover:shadow-md cursor-pointer' : ''}`}
            >
              <!-- Icon + Title -->
              <div class="flex items-center gap-3">
                <span class="text-3xl leading-none">{project.icon}</span>
                <h2 class="text-lg font-bold text-zinc-900">{project.title}</h2>
              </div>

              <!-- Description -->
              <p class="text-sm text-zinc-600 leading-relaxed flex-1">
                {project.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="px-2.5 py-0.5 rounded-full bg-zinc-200 text-zinc-700 text-xs font-medium">
                    {tag}
                  </span>
                ))}
              </div>
            </Tag>
          )
        })
      }
    </div>
  </div>
</BaseLayout>
