---
const { page } = Astro.props
---

<nav class="flex justify-center items-center gap-4 mt-12 mb-8">
  {
    page.url.prev && (
      <a
        href={page.url.prev}
        class="px-4 py-2 text-zinc-600 rounded-lg hover:text-zinc-900 transition-colors"
        style="background-color: var(--color-card-bg);"
      >
        ← 上一頁
      </a>
    )
  }

  <div class="text-zinc-500 font-mono text-sm whitespace-nowrap">
    Page {page.currentPage} / {page.lastPage}
  </div>

  {
    page.url.next && (
      <a
        href={page.url.next}
        class="px-4 py-2 text-zinc-600 rounded-lg hover:text-zinc-900 transition-colors"
        style="background-color: var(--color-card-bg);"
      >
        下一頁 →
      </a>
    )
  }
</nav>
